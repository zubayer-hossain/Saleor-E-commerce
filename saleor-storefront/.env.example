# Saleor API URL (required) - keep the trailing slash
# Must be reachable from the browser (e.g. localhost when API is on the same machine).
NEXT_PUBLIC_SALEOR_API_URL=https://your-instance.saleor.cloud/graphql/

# Optional: GraphQL URL for Next.js server-side only (Docker storefront). Use when the browser
# cannot resolve the same host as Node (e.g. SALEOR_API_SERVER_URL=http://host.docker.internal:8000/graphql/).
# SALEOR_API_SERVER_URL=

# Storefront URL - set on production for correct canonical URLs and OG images
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Origin Saleor Core/worker POSTs refund + invoice webhooks to. Use Docker service hostname when
# Saleor runs in Compose (compose sets http://storefront:3000). Host-only Next.js → host.docker.internal:3000.
# SALEOR_WEBHOOK_TARGET_ORIGIN=http://storefront:3000

# Channel slug (required) - your Saleor channel identifier
# The root "/" redirects to this channel (e.g., "/default-channel")
NEXT_PUBLIC_DEFAULT_CHANNEL=shop

# App token (optional) - enables multi-channel builds by discovering additional channels
# SALEOR_APP_TOKEN=

# -------- Stripe direct integration (test mode) --------
# Browser key. Use pk_test_… for test mode. Required by Stripe.js + PaymentElement.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server key. Use sk_test_… for test mode. Used by /api/stripe/* route handlers.
STRIPE_SECRET_KEY=
# Webhook signing secret printed by `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
STRIPE_WEBHOOK_SECRET=

# Saleor App token with HANDLE_PAYMENTS + MANAGE_CHECKOUTS + MANAGE_APPS permissions.
# (MANAGE_ORDERS recommended too, for invoice rendering.)
# Create in Saleor Dashboard → Apps → Create local app, then copy the token here.
# Required so /api/stripe/* can call transactionCreate, transactionEventReport, checkoutComplete,
# and so /api/saleor/install can register Dashboard refund/invoice webhooks on the app.
SALEOR_APP_TOKEN_PAYMENTS=

# Shared secret used to HMAC-verify inbound Saleor sync webhooks
# (refund + invoice). Generate with:  openssl rand -hex 32
# After setting (and after `docker compose restart storefront`), run:
#   curl -X POST http://localhost:3000/api/saleor/install
SALEOR_WEBHOOK_SECRET=
